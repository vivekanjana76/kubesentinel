# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Default model: meta-llama/llama-3.3-70b-instruct:free
# Override: OPENROUTER_REASONING_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Per-request timeout (seconds). Prevents indefinite hangs on free-tier.
# OPENROUTER_REQUEST_TIMEOUT=90

# Gemini — reserved for long-context log analysis.
GOOGLE_API_KEY=...

# ── GitHub ────────────────────────────────────────────────────────────────────
# Agent PAT (separate from any GITHUB_MCP_TOKEN used by Claude Code).
# Required scopes: repo (full), workflow.
GITHUB_TOKEN=ghp_...
# Demo-app repo where agent-created PRs land (NEVER the kubesentinel repo).
GITHUB_AGENT_REPO_OWNER=vivekanjana76
GITHUB_AGENT_REPO_NAME=kubesentinel-demo-app

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from your Slack app's OAuth & Permissions page.
# Required scopes: chat:write, chat:write.public, channels:read,
#                  channels:history, reactions:read, files:write
# Note: adding scopes after initial install requires reinstalling the app.
SLACK_BOT_TOKEN=xoxb-...
SLACK_INCIDENTS_CHANNEL=#incidents

# ── Supabase / RAG ───────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Direct Postgres connection — used by migrate.py for DDL.
# Find this in: Supabase Dashboard > Project Settings > Database > URI mode.
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Agent Behavior ────────────────────────────────────────────────────────────
# DRY_RUN=true (default) — every destructive action is a logged no-op.
# Set false only for live demos where real PRs and cluster patches are intended.
DRY_RUN=true

# Set true to use RealToolkit (K8s + GitHub + Slack) instead of MockToolkit.
# Requires GITHUB_TOKEN, SLACK_BOT_TOKEN, and a reachable kubeconfig.
# Run `py -3.12 -m agent.cli verify-tools` first to confirm all services.
AGENT_USE_REAL_TOOLS=false

# Set true to have the /webhook/alert endpoint invoke the graph automatically.
# Keep false during development; set true only when the full stack is running.
AGENT_AUTOTRIGGER=false

# When true, kubectl_patch remediations wait for Slack emoji-reaction approval.
# Ignored in dry-run mode.
REQUIRE_SLACK_APPROVAL_FOR_PATCHES=true

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Override kubeconfig path. Leave unset to use ~/.kube/config.
# KUBECONFIG_PATH=/path/to/kubeconfig

# Hard namespace allowlist — the agent rejects operations outside these.
# ALLOWED_NAMESPACES=kubesentinel,kubesentinel-demo

# Agent-created PRs always target this branch, never main.
# PR_TARGET_BRANCH=develop

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# LangSmith tracing (optional).
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...

# Slack approval timeout for kubectl_patch remediations (seconds).
# SLACK_APPROVAL_TIMEOUT_SECONDS=300
